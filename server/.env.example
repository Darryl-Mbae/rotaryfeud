# Copy this file to .env and fill in your values

# Secret for signing session tokens — use a long random string
SESSION_SECRET=your-long-random-secret-here

# Comma-separated allowed frontend origins (no trailing slash)
# Production example: ALLOWED_ORIGINS=https://rotaryfeud.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Log level: error | warn | info | debug
LOG_LEVEL=info
